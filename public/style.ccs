:root {
  --bg: #0b1020;
  --panel: rgba(15, 23, 42, 0.72);
  --panel-strong: rgba(15, 23, 42, 0.92);
  --panel-soft: rgba(30, 41, 59, 0.58);
  --line: rgba(148, 163, 184, 0.18);
  --text: #e2e8f0;
  --muted: #94a3b8;
  --accent: #7c3aed;
  --accent-2: #22c55e;
  --danger: #ef4444;
  --shadow: 0 30px 80px rgba(0, 0, 0, 0.4);
  --radius: 28px;
  --radius-sm: 18px;
  --radius-xs: 14px;
  --font: "Inter", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

* {
  box-sizing: border-box;
}

html, body {
  margin: 0;
  min-height: 100%;
  background:
    radial-gradient(circle at top left, rgba(124, 58, 237, 0.22), transparent 28%),
    radial-gradient(circle at bottom right, rgba(34, 197, 94, 0.18), transparent 24%),
    linear-gradient(180deg, #050816, #0b1020 38%, #050816);
  color: var(--text);
  font-family: var(--font);
  overflow-x: hidden;
}

body {
  position: relative;
}

.bg-orb {
  position: fixed;
  border-radius: 999px;
  filter: blur(80px);
  opacity: 0.45;
  pointer-events: none;
  z-index: 0;
}

.orb-1 {
  width: 300px;
  height: 300px;
  top: -80px;
  left: -80px;
  background: rgba(124, 58, 237, 0.5);
}

.orb-2 {
  width: 260px;
  height: 260px;
  right: -80px;
  top: 120px;
  background: rgba(34, 197, 94, 0.38);
}

.orb-3 {
  width: 220px;
  height: 220px;
  right: 24%;
  bottom: -100px;
  background: rgba(59, 130, 246, 0.32);
}

